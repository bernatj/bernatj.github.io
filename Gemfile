# frozen_string_literal: true

source 'https://rubygems.org'

# GitHub Pages gem - includes Jekyll and necessary plugins for GitHub Pages compatibility
gem "github-pages", group: :jekyll_plugins

# Optional Gems for Additional Functionality
gem "jekyll-sitemap", group: :jekyll_plugins        # Generates a sitemap.xml for SEO purposes
gem "jekyll-feed", group: :jekyll_plugins           # Generates an RSS feed for your site
gem "jekyll-seo-tag", group: :jekyll_plugins        # Adds SEO meta tags to improve search engine optimization
gem "jekyll-archives", group: :jekyll_plugins       # Allows for creating archive pages (e.g., yearly or monthly archives)
gem "jekyll-paginate", group: :jekyll_plugins       # Pagination support for blog pages
gem "jekyll-assets", group: :jekyll_plugins         # Adds asset management for better CSS/JS handling
gem "jekyll-minifier", group: :jekyll_plugins       # Minifies HTML, CSS, and JavaScript for faster load times
gem "jekyll-include-cache", group: :jekyll_plugins  # Caches includes to improve build performance

# Optional Performance and Caching
gem "jekyll-algolia", group: :jekyll_plugins        # Algolia integration for fast, client-side search functionality

# Only include this if you are not using `github-pages`
# gem "jekyll", "~> 4.2"  # Explicit Jekyll version (avoiding potential conflicts if updating locally)

gemspec
